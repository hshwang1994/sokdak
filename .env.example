# ─── Database (SOKDAK 전용, port 5433) ───
# WARNING: 절대로 Paperclip DB URL(paperclip@localhost:5432/paperclip)을 사용하지 마세요.
# 참조: docs/policies/product-runtime-isolation.md
DATABASE_URL="postgresql://sokdak:sokdak_dev@localhost:5433/sokdak?schema=public"

# ─── Redis (SOKDAK 전용, port 6380) ───
REDIS_URL="redis://localhost:6380"

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Auth / Session ───
SESSION_SECRET="change-me-to-a-random-64-char-string"
SESSION_MAX_AGE_HOURS=168

# ─── Argon2id ───
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ─── Join Code ───
JOIN_CODE_MASTER="change-me-master-join-code"

# ─── Rate Limiting ───
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SEC=60
